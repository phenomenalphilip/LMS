VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Paystack API Keys
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# Flutterwave API Keys
FLUTTERWAVE_SECRET_KEY=
VITE_FLUTTERWAVE_PUBLIC_KEY=

# Card Token Encryption Key (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# KEEP THIS SECRET — losing it makes all saved card tokens unreadable
CARD_TOKEN_ENCRYPTION_KEY=

# Get these from Mux Dashboard -> Settings -> API Keys -> Generate new key (Signing Key)
# Supports raw PEM or flat Base64-encoded PEM string.
MUX_SIGNING_KEY_ID=
MUX_SIGNING_KEY_SECRET=

# Alternatively, the following names are also supported:
# MUX_SIGNING_KEY=
# MUX_PRIVATE_KEY=
